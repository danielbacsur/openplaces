{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },

    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "//#vitest": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "openplaces/**",
        "openplaces-atlas/**",
        "openplaces-mcp/**",
        "openplaces-website/**"
      ],
      "outputs": []
    }
  }
}
